# ============================================================
# MechTrack Pulse — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=MechTrack Pulse
APP_VERSION=1.0.0
DEBUG=true

# ── Database ─────────────────────────────────────────────────
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mechtrack_pulse

# ── JWT ──────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
BCRYPT_ROUNDS=12

# ── Storage (Phase 5) ───────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# ── Platform Admin Seed ──────────────────────────────────────
PLATFORM_ADMIN_EMAIL=admin@mechtrackpulse.com
PLATFORM_ADMIN_PASSWORD=Admin@12345

# ── SMTP Email Delivery ──────────────────────────────────────
# Fill these to email owner temp passwords on approval.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mechtrackpulse.com
SMTP_FROM_NAME=MechTrack Pulse
SMTP_USE_TLS=true
SMTP_USE_SSL=false
